{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the AGV Fleet VLA Intelligence Dashboard.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "operator"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "IncidentReport": {
      "title": "Incident Report",
      "description": "An incident report generated by an AGV and analyzed by the VLA system.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier of the incident report."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the incident occurred."
        },
        "operatorId": {
          "type": "string",
          "description": "The UID of the operator who reviewed or triggered the report."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "resolved"],
          "description": "The status of the incident report."
        },
        "feedback": {
          "type": "string",
          "enum": ["good", "bad"],
          "description": "User feedback on the analysis."
        },
        "operator_action": {
          "type": "string",
          "description": "The action taken by the operator, e.g., 'Force Override'."
        },
        "overridden": {
          "type": "boolean",
          "description": "Whether the operator overridden the stop decision."
        },
        "override_warning_shown": {
          "type": "string",
          "description": "The specific warning message shown to the operator when they forced an override."
        },
        "telemetry": {
          "type": "string",
          "description": "The raw telemetry data from the AGV."
        },
        "avgSpeed": {
          "type": "number",
          "description": "Average speed before stop in km/h."
        },
        "distance": {
          "type": "number",
          "description": "Distance to object in meters."
        },
        "lat": {
          "type": "number",
          "description": "Location latitude."
        },
        "lng": {
          "type": "number",
          "description": "Location longitude."
        },
        "audioUrl": {
          "type": "string",
          "description": "The base64 encoded audio of the incident."
        },
        "operator_feedback_notes": {
          "type": "string",
          "description": "Transcribed or typed operator feedback."
        },
        "imageUrl": {
          "type": "string",
          "description": "The base64 encoded image of the incident."
        },
        "analysis": {
          "type": "object",
          "description": "The VLA analysis of the incident.",
          "properties": {
            "perception_engine": {
              "type": "object",
              "properties": {
                "media_analyzed": { "type": "string" },
                "scene_context": { "type": "string" },
                "critical_object_identified": { "type": "string" },
                "spatial_location": { "type": "string" },
                "kinetic_state": { "type": "string" }
              }
            },
            "reasoning_and_commentary": {
              "type": "object",
              "properties": {
                "audio_map_fusion": { "type": "string" },
                "location_anomaly_check": { "type": "string" },
                "operator_commentary": { "type": "string" }
              }
            },
            "action_policy": {
              "type": "object",
              "properties": {
                "danger_score": { "type": "number" },
                "recommended_action": { "type": "string" },
                "diagnostic_report_for_database": { "type": "string" }
              }
            },
            "ui_triggers": {
              "type": "object",
              "properties": {
                "dashboard_color": { "type": "string" },
                "tts_audio_alert": { "type": "string" }
              }
            }
          }
        }
      },
      "required": ["id", "timestamp", "operatorId", "status", "analysis"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/incident_reports/{reportId}": {
      "schema": {
        "$ref": "#/entities/IncidentReport"
      },
      "description": "Stores AGV incident reports."
    }
  }
}
