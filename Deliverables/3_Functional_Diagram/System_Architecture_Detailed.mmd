graph TD
    classDef physical fill:#1E40AF,stroke:#1E3A8A,stroke-width:2px,color:#fff
    classDef ingest   fill:#0369A1,stroke:#075985,stroke-width:2px,color:#fff
    classDef auth     fill:#0F766E,stroke:#115E59,stroke-width:2px,color:#fff
    classDef service  fill:#059669,stroke:#047857,stroke-width:2px,color:#fff
    classDef ai       fill:#7C3AED,stroke:#6D28D9,stroke-width:2px,color:#fff
    classDef operator fill:#D97706,stroke:#B45309,stroke-width:2px,color:#fff
    classDef db       fill:#DC2626,stroke:#B91C1C,stroke-width:2px,color:#fff

    subgraph S1["① Physical AGV Environment"]
        direction LR
        C["Camera"]:::physical
        P["Proximity Sensor"]:::physical
        M["Microphone"]:::physical
    end

    subgraph S2["② Data Ingestion  (API in production · Simulated in prototype)"]
        direction LR
        VI["Visual Evidence"]:::ingest
        TD["Telemetry Data"]:::ingest
        AU["Audio Evidence"]:::ingest
    end

    C -->|Frame| VI
    P -->|Payload| TD
    M -->|Blob| AU

    FB["③ Firebase Auth\nRoute Guard · Google Sign-In\noperatorId → Firestore"]:::auth

    VI --> FB
    TD --> FB
    AU --> FB

    subgraph S4["④ Client-side Prompt Assembly"]
        direction LR
        HF["History Retrieval\nTop-K Past Events"]:::service
        PA["Prompt Builder\nImage · Audio · Telemetry · History"]:::service
    end

    FB -->|Session| PA
    HF -->|Top-K| PA
    FS -.->|Past Records| HF

    GM["⑤ Gemini VLA\ngemini-3-flash-preview · Temp 0.0\nSchema-Constrained JSON"]:::ai

    PA -->|Multimodal Prompt| GM

    subgraph S6["⑥ Result & Persistence"]
        direction LR
        DV["Assessment Viewer\nScore · Recommendation"]:::service
        FS[("Firestore DB")]:::db
    end

    GM -->|4-Block JSON| DV
    GM -.->|Auto-save Inference| FS

    subgraph S7["⑦ Operator Decision"]
        DC["Decision\nOverride · Confirm · Feedback"]:::operator
    end

    DV -->|Reviews| DC
    DC -->|Writes Decision| FS
